{
    "source": {
        "file_path": "/datasets/fraud.csv"
    },
    "output": "fraud-transactions-detection",
    "date_column": "rep_loan_date",
    "target_column": "bad_flag",
    "outliers": {
        "criterion": "IQR",
        "multiplier_iqr": 1.5,
        "threshold_z_score": 3.0
    },
    "markdown": {
        "name": "README.md",
        "css_style": "style.css",
        "float_precision": 4
    },
    "plotly": {
        "plot": {
            "mode": "lines+markers",
            "line": {
                "color": "dodgerblue",
                "dash": "dash",
                "width": 0.8
            },
            "marker": {
                "size": 6,
                "symbol": "circle",
                "color": "white",
                "line": {
                    "color": "dodgerblue",
                    "width": 0.5
                }
            }
        },
        "outliers": {
            "style": {
                "type": "rect",
                "xref": "x",
                "yref": "y",
                "fillcolor": "grey",
                "opacity": 0.05,
                "line": {
                    "width": 1.0,
                    "dash": "dot",
                    "color": "black"
                }
            }
        },
        "layout": {
            "template": "plotly_white",
            "margin": { "l": 20, "r": 20, "t": 30, "b": 20 },
            "showlegend": false,
            "height": 480,
            "width": 700
        },
        "annotations": {
            "xanchor": "right",
            "yanchor": "bottom",
            "x_offset": 0.005,
            "y_offset": 0.005
        },
        "grid": {
            "automargin": true,
            "gridcolor": "rgba(128,128,128,0.3)",
            "griddash": "dot",
            "gridwidth": 0.5
        },
        "subplots": {
            "horizontal_spacing": 0.05,
            "vertical_spacing": 0.065
        },
        "scale_factor": 3,
        "format": "PNG",
        "tickformat": "%Y-%m-%d"
    }
}
